
# Veritabani
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SIFRENIZI_BURAYA_YAZIN
POSTGRES_DB=SkorTakipDB

# JWT (en az 32 karakter, rastgele olustur: openssl rand -base64 32)
JWT_SECRET=EN_AZ_32_KARAKTER_RASTGELE_DEGER

# Admin hesabi (ilk calistirmada otomatik olusturulur)
ADMIN_EMAIL=admin@skortakip.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GUCLU_BIR_SIFRE_YAZIN

# API Sports anahtarlari (https://api-sports.io adresinden alin)
FOOTBALL_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
BASKETBALL_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
VOLLEYBALL_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# CollectAPI anahtari — futbol puan durumu icin (https://collectapi.com)
COLLECT_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# CollectAPI Sport — gol krallığı icin (https://collectapi.com)
SPORT_COLLECT_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# Google Gemini AI — giriş yapan kullanıcılar için spor sohbeti (https://ai.google.dev)
GEMINI_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# NewsData.io — spor haberleri (https://newsdata.io) — VITE_ öneki gerekli
VITE_NEWS_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# CORS (frontend URL'i)
ALLOWED_ORIGINS=http://localhost:3000
