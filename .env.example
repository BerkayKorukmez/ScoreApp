
# ─────────────────────────────────────────────────────────────────────
# SkorTakip — Ortam değişkenleri şablonu
#
# Kurulum:
#   1. Bu dosyayı `.env` olarak kopyalayın:  Copy-Item .env.example .env
#   2. Aşağıdaki tüm "CHANGE_ME" değerlerini güçlü / gerçek değerlerle değiştirin.
#   3. .env dosyası asla Git'e eklenmez (.gitignore içinde korunuyor).
#   4. Üretime dağıtımdan önce .env'deki tüm anahtarları mutlaka ROTATE EDİN
#      (eski anahtarlar geliştirme ortamında sızmış olabilir).
# ─────────────────────────────────────────────────────────────────────

# ── Veritabanı ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=SkorTakipDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── JWT ─────────────────────────────────────────────────────────────
# EN AZ 32 karakter olmak ZORUNDA. Üretmek için:
#   PowerShell: [Convert]::ToBase64String((1..48 | %{ Get-Random -Min 0 -Max 255 }))
#   Linux/Mac:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS

# ── Admin hesabı (ilk çalıştırmada otomatik oluşturulur) ────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
# En az 8 karakter, büyük+küçük harf+rakam içermeli.
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── API-Sports (https://api-sports.io) ──────────────────────────────
# Tek bir abonelik tüm sporlar için aynı anahtarı verir.
FOOTBALL_API_KEY=CHANGE_ME
BASKETBALL_API_KEY=CHANGE_ME
VOLLEYBALL_API_KEY=CHANGE_ME

# ── Google Gemini (https://ai.google.dev) — AI sohbet + maç önizlemesi
GEMINI_API_KEY=CHANGE_ME
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ── NewsData.io — haber proxy'si (frontend'e anahtar gitmez) ────────
NEWS_API_KEY=CHANGE_ME

# ── CORS (izinli origin'ler, virgülle ayrılmış) ─────────────────────
# Üretimde yalnız gerçek domain olsun (örn: https://skortakip.com,https://www.skortakip.com)
# Geliştirme: http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
