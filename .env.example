
# Kopyalayın: Copy-Item .env.example .env  —  Gerçek değerleri .env içinde tutun; .env git'e eklenmez.

# Veritabani
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SIFRENIZI_BURAYA_YAZIN
POSTGRES_DB=SkorTakipDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT (en az 32 karakter, rastgele olustur: openssl rand -base64 32)
JWT_SECRET=EN_AZ_32_KARAKTER_RASTGELE_DEGER

# Admin hesabi (ilk calistirmada otomatik olusturulur)
ADMIN_EMAIL=admin@skortakip.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GUCLU_BIR_SIFRE_YAZIN

# API-Sports (https://api-sports.io) — spor basina; tenis icin genelde futbol anahtariyla ayni abonelik
FOOTBALL_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
BASKETBALL_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
VOLLEYBALL_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
TENNIS_API_KEY=

# CollectAPI (https://collectapi.com)
COLLECT_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
SPORT_COLLECT_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# Google Gemini (https://ai.google.dev) — AI sohbet + maç önizlemesi yedek anahtar
GEMINI_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Opsiyonel: Maç YZ önizlemesi icin ayri anahtar; bos birakilirsa GEMINI_API_KEY kullanilir
MATCH_PREVIEW_GEMINI_API_KEY=
MATCH_PREVIEW_GEMINI_MODEL=

# NewsData.io — haberler (backend /api/news/sports)
NEWS_API_KEY=API_ANAHTARINIZI_BURAYA_YAZIN

# CORS (Vite 5173 + Docker 3000)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
